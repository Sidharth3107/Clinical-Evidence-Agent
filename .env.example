# Copy this file to `.env` (which is gitignored) and fill in your values.
# NEVER put real keys in this file or commit them.

# --- Anthropic API (agent + LLM-as-judge) ---
ANTHROPIC_API_KEY=

# --- NCBI E-utilities (PubMed retrieval) ---
# A free API key raises the rate limit from 3 -> 10 requests/sec.
# Get one at https://www.ncbi.nlm.nih.gov/account/  (Settings -> API Key Management)
NCBI_API_KEY=
NCBI_EMAIL=

# --- AWS (only needed in Step 7, SageMaker Serverless Inference) ---
AWS_REGION=us-east-1
